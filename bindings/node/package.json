{
  "name": "disarm",
  "version": "0.0.0",
  "description": "Unicode confusable/text-security building blocks, powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raeq/disarm.git",
    "directory": "bindings/node"
  },
  "homepage": "https://docs.disarm.dev",
  "keywords": [
    "unicode",
    "confusable",
    "homoglyph",
    "transliterate",
    "slugify",
    "security",
    "tr39",
    "napi-rs"
  ],
  "engines": {
    "node": ">= 14"
  },
  "napi": {
    "name": "disarm",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.js",
    "binding.d.ts",
    "disarm.*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release --js binding.js --dts binding.d.ts && tsc",
    "build:debug": "napi build --platform --js binding.js --dts binding.d.ts && tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
