{
  "name": "disarm",
  "version": "0.11.1",
  "description": "Unicode confusable/text-security building blocks, powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raeq/disarm.git",
    "directory": "bindings/node"
  },
  "homepage": "https://docs.disarm.dev",
  "keywords": [
    "unicode",
    "confusable",
    "homoglyph",
    "transliterate",
    "slugify",
    "security",
    "tr39",
    "napi-rs"
  ],
  "engines": {
    "node": ">= 14"
  },
  "napi": {
    "binaryName": "disarm",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.js",
    "binding.d.ts",
    "disarm.*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release --js binding.js --dts binding.d.ts && tsc",
    "build:debug": "napi build --platform --js binding.js --dts binding.d.ts && tsc",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@napi-rs/cli": "^3.7.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
