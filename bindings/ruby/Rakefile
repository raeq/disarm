# frozen_string_literal: true

require "bundler/gem_tasks"
require "rake/extensiontask"

# Platforms for the precompiled native gems (#45 acceptance: `gem install disarm`
# pulls a platform gem and runs with no local Rust toolchain). Built in CI via
# rb-sys-dock; locally `rake compile` builds for the host only.
CROSS_PLATFORMS = %w[
  aarch64-linux
  arm64-darwin
  x86_64-darwin
  x86_64-linux
  x64-mingw-ucrt
].freeze

Rake::ExtensionTask.new("disarm") do |ext|
  ext.lib_dir = "lib/disarm"
  ext.ext_dir = "ext/disarm"
  ext.cross_compile = true
  ext.cross_platform = CROSS_PLATFORMS
end

# rspec is a development-only dependency. The cross-gem build container
# (rb-sys-dock, used by `rake native gem` in CI) installs only build deps, so
# requiring it at the top would abort the whole Rakefile with a LoadError there.
# Define the `spec` task only when rspec is actually present.
spec_available =
  begin
    require "rspec/core/rake_task"
    RSpec::Core::RakeTask.new(:spec)
    true
  rescue LoadError
    false
  end

task build: :compile
task default: (spec_available ? %i[compile spec] : %i[compile])
