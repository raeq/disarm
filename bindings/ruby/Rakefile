# frozen_string_literal: true

require "bundler/gem_tasks"
require "rb_sys/extensiontask"

GEMSPEC = Gem::Specification.load("disarm.gemspec")

# rb-sys's ExtensionTask (NOT rake-compiler's bare `Rake::ExtensionTask`) defines
# the `native:<platform>` / cross-gem tasks the rb-sys-dock cross-gem build runs,
# in addition to `compile`. The name here drives BOTH the cargo-crate lookup and
# the built `.so` name, so it must be `disarm` (matching the gem, the `[lib]`, the
# magnus init, and the `require "disarm/disarm"` loader). The ext crate is named
# `disarm` too but pinned to a *different version* (0.0.0) than the core (0.10),
# so the two `disarm` crates coexist in the lockfile without colliding. The
# gem-root `Cargo.toml` workspace is what lets `cargo metadata` (run from here)
# resolve to `ext/disarm` instead of the repo-root core crate. (#45 cross-gem)
RbSys::ExtensionTask.new("disarm", GEMSPEC) do |ext|
  ext.lib_dir = "lib/disarm"
end

# rspec is a development-only dependency. The cross-gem build container
# (rb-sys-dock) installs only build deps, so requiring it at load time would abort
# the whole Rakefile there with a LoadError. Define the `spec` task only when
# rspec is actually present.
spec_available =
  begin
    require "rspec/core/rake_task"
    RSpec::Core::RakeTask.new(:spec)
    true
  rescue LoadError
    false
  end

task build: :compile
task default: (spec_available ? %i[compile spec] : %i[compile])
